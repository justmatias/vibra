# Spotify API Credentials
# Get these from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here
# For the REST API (Next.js frontend), set this to the frontend callback route,
# e.g. http://localhost:3000/auth/callback
# For the legacy Streamlit UI: http://127.0.0.1:8501/callback
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8501/callback

# API server settings
# Comma-separated list of allowed CORS origins for the REST API
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Genius API Credentials
GENIUS_API_KEY=your_genius_api_key_here

# LLM Settings (Ollama)
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=llama3.2:3b
EMBEDDING_MODEL=nomic-embed-text:v1.5
TEMPERATURE=0.7
